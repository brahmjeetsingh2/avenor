# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=production

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/avenor?retryWrites=true&w=majority&appName=Avenor

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=<64-char-random-hex>
JWT_REFRESH_SECRET=<64-char-random-hex>
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# Get from: https://console.upstash.com → Create Database → REST API
REDIS_URL=rediss://:your_password@your-db.upstash.io:6379

# ─── Client URL (your Vercel domain) ─────────────────────────────────────────
CLIENT_URL=https://avenor.vercel.app

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Enable 2FA on Gmail → App Passwords → Generate
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# ─── AI (Grok) ───────────────────────────────────────────────────────────────
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── Atlas Search ─────────────────────────────────────────────────────────────
ATLAS_SEARCH_ENABLED=true

# ─── Google OAuth (Part 11 bonus) ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://avenor-api.onrender.com/api/auth/google/callback
